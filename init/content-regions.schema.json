{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora.studio/schemas/content-regions.json",
  "title": "Marketplace template CMS content slots",
  "type": "object",
  "required": ["version", "generatedAt", "legacyAliases", "templates"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "legacyAliases": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "templates": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["page", "region", "label"],
          "additionalProperties": false,
          "properties": {
            "page": { "type": "string", "minLength": 1 },
            "region": { "type": "string", "minLength": 1 },
            "label": { "type": "string" }
          }
        }
      }
    }
  }
}
