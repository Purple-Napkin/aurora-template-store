# Aurora API - from Aurora Studio dashboard when deploying
NEXT_PUBLIC_AURORA_API_URL=https://api.yourapp.com
# Server-side (preferred for startup sync); falls back to NEXT_PUBLIC_*
# AURORA_API_URL=https://api.yourapp.com
AURORA_API_KEY=aur_xxx
# Set to 1 to skip init/schema provision + run-schema-migration on server start (e.g. CI)
# AURORA_SKIP_STARTUP_SYNC=1
NEXT_PUBLIC_TENANT_SLUG=your-tenant

# After schema:provision, load demo catalog + CMS blocks (no manual tenant id):
# pnpm seed:apply
# Catalogue empty state also offers "Use example data" (same API flow).

# Branding (optional)
NEXT_PUBLIC_SITE_NAME=Example Store
NEXT_PUBLIC_LOGO_URL=/template-logo.png
NEXT_PUBLIC_THEME=dark